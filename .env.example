# Copy to `.env.local` and fill in your values (never commit secrets).

# Tina CMS тАФ blog at `/posts`, editor at `/admin` (see docs/TEMPLATE_SETUP.md)
# Create a project at https://app.tina.io and link this GitHub repo.
# NEXT_PUBLIC_TINA_CLIENT_ID=
# TINA_TOKEN=
# Optional default content branch (else Vercel git branch / HEAD is used)
# NEXT_PUBLIC_TINA_BRANCH=main

# Google reCAPTCHA (contact form)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
# Server-only: verify token in `/api/email/send` if you implement that route
# RECAPTCHA_SECRET_KEY=

# Default NetEase playlist for the music player (optional; see docs/TEMPLATE_SETUP.md)
# NEXT_PUBLIC_NETEASE_PLAYLIST_ID=

# GitHub profile card on /about (public REST API; optional token for higher limits + contribution count)
# NEXT_PUBLIC_GITHUB_USERNAME=your_login
# GITHUB_TOKEN=

# Upstash Redis тАФ unique visitor counter (`/api/visitors`, SiteVisitorStats on /about)
# https://upstash.com/docs/redis/overall/getstarted
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Add your email/API keys for `/api/email/send` or other routes here.
