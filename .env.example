# Copy to `.env.local` and fill in your values (never commit secrets).

# Header/footer logo URL (optional; default is Usagi GIF in `src/components/layout/Logo.jsx`)
# NEXT_PUBLIC_SITE_LOGO_URL=https://example.com/logo.png

# About section profile image (optional; default Usagi name card from Chiikawa Wiki)
# NEXT_PUBLIC_ABOUT_AVATAR_URL=https://example.com/me.jpg

# Tina CMS — blog at `/posts`, admin at `/admin` (see docs/TEMPLATE_SETUP.md)
# Create project + token at https://app.tina.io → link this GitHub repo
# NEXT_PUBLIC_TINA_CLIENT_ID=
# TINA_TOKEN=
# NEXT_PUBLIC_TINA_BRANCH=main

# Google reCAPTCHA (contact form)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
# Server-only: verify token in `/api/email/send` if you implement that route
# RECAPTCHA_SECRET_KEY=

# Default NetEase playlist for the music player (optional; see docs/TEMPLATE_SETUP.md)
# NEXT_PUBLIC_NETEASE_PLAYLIST_ID=

# GitHub profile card on /about (public REST API; optional token for higher limits + contribution count)
# NEXT_PUBLIC_GITHUB_USERNAME=your_login
# GITHUB_TOKEN=

# Upstash Redis — unique visitor counter (`/api/visitors`, SiteVisitorStats on /about)
# https://upstash.com/docs/redis/overall/getstarted
# Use REST URL + token from Upstash console (no quotes around values):
# UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=...

# Add your email/API keys for `/api/email/send` or other routes here.
